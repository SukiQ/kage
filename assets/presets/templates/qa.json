      {
        "name": "phenomenon",
        "label": "现象描述",
        "required": true,
        "multiline": true
      }
    ],
    "body": "请把以下现象整理为最小可复现步骤，并标注可能的影响范围与定位思路：\n{{phenomenon}}"
